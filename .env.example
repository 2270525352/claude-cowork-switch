HOST=127.0.0.1
PORT=8787

# Optional. If omitted, the app generates data/state.json with a local Gateway key.
# BRIDGE_API_KEY=change-this

# Optional fallback when a cc-switch Claude provider does not pin a model.
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4

# auto: Claude-like providers use the official Claude model list.
# provider: keep cc-switch/profile model lists exactly.
# official: force the official Claude model list for every Anthropic-compatible provider.
CLAUDE_GATEWAY_MODEL_SOURCE=auto
CLAUDE_GATEWAY_OFFICIAL_MODELS=claude-sonnet-4-6[1m],claude-opus-4-7[1m],claude-opus-4-6[1m],claude-haiku-4-5-20251001

# Optional overrides for non-standard cc-switch locations.
# CCSWITCH_HOME=/Users/you/.cc-switch
# CCSWITCH_DB_PATH=/Users/you/.cc-switch/cc-switch.db
# CLAUDE_PROFILES_DIR=/Users/you/.claude/profiles
